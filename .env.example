# nybble endpoint configuration.
# Copy to ~/.config/nybble/.env (or ./.env) and fill in your deployment's URLs.
# Real environment variables override these. NEVER commit a filled-in .env.

NYBBLE_API_BASE=https://<host>/<app-path>
NYBBLE_LOGIN_URL=https://<host>/<login-path>

# Everything else — your building, pickup point, meal slot, and notification target —
# is detected from your session during `nybble auth` and set in the TUI, not here.
