# canteen endpoint configuration.
# Copy to ~/.config/canteen/.env (or ./.env) and fill in your deployment's URLs.
# Real environment variables override these. NEVER commit a filled-in .env.

CANTEEN_API_BASE=https://<host>/<app-path>
CANTEEN_LOGIN_URL=https://<host>/<login-path>

# Optional: Lark receive-id (ou_… or oc_…) for booking notifications.
# CANTEEN_LARK_TARGET=ou_xxxxxxxx
